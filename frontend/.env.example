# =========================================================
# Frontend environment variables (Next.js)
# Copy to .env.local for local dev, and add these in the
# Vercel dashboard (Project Settings > Environment Variables).
# Only NEXT_PUBLIC_* vars are exposed to the browser.
# =========================================================

# REQUIRED: URL of your already-deployed backend (no trailing slash)
# e.g. https://croprakshak-backend.onrender.com
NEXT_PUBLIC_API_URL=https://your-deployed-backend-url

# OPTIONAL: Supabase auth (signup page). App works without these.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OPTIONAL: enable installable/offline PWA (leave unset to keep it off)
# NEXT_PUBLIC_ENABLE_PWA=true
